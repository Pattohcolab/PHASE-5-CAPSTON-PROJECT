   "source": [
    "# pull a real month from the test period\n",
    "# (2022+) that this model was actually evaluated on -- and cross-check that scoring\n",
    "# it through the production pipeline gives the exact same numbers as test_results_df.\n",
    "test_month_df = model_df[model_df['reporting_date'] >= '2022-01-01'].copy()\n",
    "\n",
    "# Pick a month with a realistic mix of outcomes (not the easiest or hardest one) --\n",
    "# here, the month whose crisis rate is closest to the overall test-set crisis rate,\n",
    "# so the demo isn't accidentally cherry-picked.\n",
    "overall_crisis_rate = test_month_df['crisis'].mean()\n",
    "monthly_rates = test_month_df.groupby('reporting_date')['crisis'].mean()\n",
    "demo_month = (monthly_rates - overall_crisis_rate).abs().idxmin()\n",
    "\n",
    "new_month_df = model_df[model_df['reporting_date'] == demo_month].copy().reset_index(drop=True)\n",
    "print(f\"Demo month: {demo_month.strftime('%B %Y')}  \"\n",
    "      f\"(crisis rate {new_month_df['crisis'].mean():.1%}, vs. {overall_crisis_rate:.1%} test-set average)\")\n",
    "\n",
    "# Score through the exact production function.\n",
    "scored = score_new_month(new_month_df, prod_model, prod_imputer, feature_cols, prod_meta['threshold'])\n",
    "bulletin = pd.concat([new_month_df[['county']], scored,\n",
    "                       new_month_df[['crisis']].rename(columns={'crisis': 'actual_outcome'})], axis=1)\n",
    "bulletin = bulletin.sort_values('crisis_probability', ascending=False).reset_index(drop=True)\n",
    "\n",
    "# Cross-check: these probabilities should exactly match what test_proba_all already\n",
    "# computed for these same rows, proving the production pipeline is faithful to the\n",
    "# evaluation pipeline -- not just \"similar.\"\n",
    "test_row_mask = (model_df['reporting_date'] == demo_month).values[model_df['reporting_date'] >= '2022-01-01']\n",
    "reference_proba = test_proba_all[winner_name][test_row_mask]\n",
    "max_diff = np.abs(np.sort(scored['crisis_probability'].values) - np.sort(reference_proba)).max()\n",
    "print(f\"Cross-check vs. test_proba_all: max probability difference = {max_diff:.2e} \"\n",
    "      f\"({'MATCH' if max_diff < 1e-8 else 'MISMATCH -- investigate'})\")\n",
    "\n",
    "n_alerts = int(bulletin['alert'].sum())\n",
    "n_true_crises = int(bulletin['actual_outcome'].sum())\n",
    "print(f\"\\n{n_alerts} counties flagged out of {len(bulletin)}. \"\n",
    "      f\"{n_true_crises} counties actually reached IPC Phase 3+ that month.\")\n",
    "bulletin.style.format({'crisis_probability': '{:.1%}'}).background_gradient(subset=['crisis_probability'], cmap='Reds')"
   ]
  },
