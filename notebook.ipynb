    "    \"meru central\": \"Meru\", \"meru north\": \"Meru\", \"meru south\": \"Meru\",\n",
    "    \"moyale\": \"Marsabit\", \"mt elgon\": \"Bungoma\", \"mt. elgon\": \"Bungoma\",\n",
