    "# The 47 official Kenyan counties, in constitutional numbering order (001-047).\n",
    "# This order doubles as the PCODE lookup for the rainfall dataset.\n",
    "official_counties = [\n",
    "    \"Mombasa\", \"Kwale\", \"Kilifi\", \"Tana River\", \"Lamu\", \"Taita-Taveta\", \"Garissa\", \"Wajir\",\n",
