    "from sklearn.metrics import brier_score_loss, confusion_matrix\n",
    "\n",
    "candidates = {\n",
    "    'Logistic Regression': lr,\n",
    "    'Random Forest': rf,\n",
    "    'XGBoost': xgb,\n",
    "    'LightGBM': lgbm,\n",
    "}\n",
    "\n",
    "test_results = []\n",
    "test_proba_all, test_pred_all = {}, {}\n",
    "\n",
    "for name, clf in candidates.items():\n",
    "    proba = clf.predict_proba(X_test)[:, 1]\n",
    "    t = thresholds[name]  # safe now -- every model in `candidates` has a matching entry\n",
    "    pred = (proba >= t).astype(int)\n",
    "    test_proba_all[name], test_pred_all[name] = proba, pred\n",
    "    tn, fp, fn, tp = confusion_matrix(y_test, pred).ravel()\n",
    "    test_results.append({\n",
    "        'Model': name, 'Threshold': round(t, 2),\n",
    "        'Recall': recall_score(y_test, pred), 'Precision': precision_score(y_test, pred, zero_division=0),\n",
    "        'F1': f1_score(y_test, pred), 'ROC_AUC': roc_auc_score(y_test, proba),\n",
    "        'PR_AUC': average_precision_score(y_test, proba), 'Brier': brier_score_loss(y_test, proba),\n",
    "        'Caught': tp, 'Missed': fn, 'FalseAlarms': fp,\n",
    "    })\n",
    "\n",
    "test_results_df = pd.DataFrame(test_results).sort_values('PR_AUC', ascending=False).reset_index(drop=True)\n",
    "total_crisis, total_safe = int(y_test.sum()), int((y_test == 0).sum())\n",
    "\n",
    "print(f\"Test-set results (2022+, {total_crisis} true crisis county-months, {total_safe} non-crisis):\")\n",
    "test_results_df.round(3)"
   ]
  },
