    "food_agg = (food_staple.groupby(['county', 'year', 'month'], as_index=False)\n",
    "            .agg(staple_price_kes=('price', 'mean'), staple_price_usd=('usdprice', 'mean'),\n",
    "                 n_price_obs=('price', 'count')))\n",
    "print(\"Food aggregated to:\", food_agg.shape)"
